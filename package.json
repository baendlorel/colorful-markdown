{
  "name": "colorful-markdown",
  "displayName": "Colorful Markdown",
  "description": "Color markdown elements with configurable background, color, decoration and font weight.",
  "description_zh": "为 Markdown 元素上色，可配置 background、color、decoration、fontweight。",
  "version": "0.1.0",
  "purpose": "vscode-extension",
  "publisher": "KasukabeTsumugi",
  "engines": {
    "vscode": "^1.74.0"
  },
  "author": {
    "email": "futami16237@gmail.com",
    "name": "Kasukabe Tsumugi"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "color",
    "style",
    "highlight",
    "decoration",
    "fontweight"
  ],
  "homepage": "https://github.com/baendlorel/colorful-markdown#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/baendlorel/colorful-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/baendlorel/colorful-markdown/issues"
  },
  "license": "MIT",
  "icon": "assets/idea.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:colorful-markdown.refreshStyles",
    "onCommand:colorful-markdown.openConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorful-markdown.refreshStyles",
        "title": "%command.refreshStyles.title%",
        "category": "%extension.category%"
      },
      {
        "command": "colorful-markdown.openConfig",
        "title": "%command.openConfig.title%",
        "category": "%extension.category%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "colorful-markdown.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.enabled.description%"
        },
        "colorful-markdown.styles": {
          "type": "object",
          "default": {
            "heading": {
              "color": "#ff7f50",
              "fontweight": "700",
              "outline": "1px solid #ff7f5033",
              "borderRadius": "3px"
            },
            "blockquote": {
              "color": "#6aa6ff",
              "decoration": "underline wavy #6aa6ff66"
            },
            "list": {
              "color": "#ffd166"
            },
            "bold": {
              "color": "#ff4d6d",
              "fontweight": "700"
            },
            "italic": {
              "color": "#2ec4b6",
              "decoration": "underline dotted #2ec4b655",
              "fontstyle": "italic"
            },
            "strikethrough": {
              "color": "#f28482",
              "decoration": "line-through"
            },
            "link": {
              "color": "#4cc9f0",
              "decoration": "underline"
            },
            "inlineCode": {
              "background": "#1f1f1f66",
              "color": "#9ef01a",
              "fontweight": "600",
              "border": "1px solid #9ef01a55",
              "borderRadius": "4px"
            },
            "codeFence": {
              "background": "#0b254566",
              "color": "#caf0f8",
              "border": "1px solid #caf0f833"
            }
          },
          "markdownDescription": "%configuration.styles.description%"
        }
      }
    }
  },
  "scripts": {
    "lines": "clear && find ./src -type f \\( -name \"*.ts\" -o -name \"*.tsx\" -o -name \"*.js\" -o -name \"*.mjs\" -o -name \"*.cjs\" -o -name \"*.cpp\" -o -name \"*.h\" -o -name \"*.py\"  -o -name \"*.css\" -o -name \"*.rs\" -o -name \"*.rc\" \\) | xargs wc -l",
    "test-build": "rimraf out && export NODE_ENV=dev && tsx ./.scripts/rollup.ts",
    "build": "rimraf out &&  tsx ./.scripts/rollup.ts",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p tsconfig.build.json",
    "lint": "oxlint .",
    "pub": "vsce package -o ./bin",
    "publish": "pnpm build && vsce publish"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.7.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "oxlint": "^1.22.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.52.4",
    "rollup-plugin-conditional-compilation": "^2.1.2",
    "rollup-plugin-const-enum": "^1.1.5",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-func-macro": "^1.2.2",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
